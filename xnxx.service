[Unit]
Description=xnxx Service
After=network.target nss-lookup.target
Wants=network.target

[Service]
User=root
Group=root
Type=simple
LimitAS=infinity
LimitRSS=infinity
LimitCORE=infinity
LimitNOFILE=999999
WorkingDirectory=/usr/local/xnxx/
ExecStart=/usr/local/xnxx/xnxx server
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
